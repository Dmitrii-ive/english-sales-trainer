# Vercel Postgres connection string. Get it with: vercel env pull .env.local
POSTGRES_URL=

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Bcrypt hash of the app password. Generate with: npm run hash-password -- 'your-password'
APP_PASSWORD_HASH=

# Bearer token for /api/tasks and /api/weekly-plan (used by Claude in meeting-analysis sessions).
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=
